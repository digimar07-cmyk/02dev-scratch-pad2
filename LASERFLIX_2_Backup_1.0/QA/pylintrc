[MASTER]
ignore=__pycache__,laserflix_backups,docs,EXTRAS
ignore-patterns=.*\.backup.*,.*\.pyc

[MESSAGES CONTROL]
disable=C0114,C0115,C0116

[DESIGN]
max-line-length=120
max-args=8
max-attributes=12
max-bool-expr=5
max-branches=12
max-locals=15
max-returns=6
max-statements=50
max-parents=7

[SIMILARITIES]
min-similarity-lines=6
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=no
